# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────────────────────────
# Local network Mongo, or swap for your MongoDB Atlas SRV string.
MONGODB_URI=mongodb://192.168.5.57:27017/field-tracking

# ── Auth (CHANGE THESE — use long random strings in production) ─────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string-min-16-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── CORS (admin dashboard origins; comma-separated, or * for dev) ───────────
CORS_ORIGINS=http://localhost:5173, https://fieldtracking.vmukti.com:5173

# ── Geofence / tracking tuning ──────────────────────────────────────────────
DEFAULT_OFFICE_RADIUS_M=1000
STOP_RADIUS_M=30
STOP_MIN_DURATION_MIN=5
MOVING_SPEED_THRESHOLD_KMH=3
OFFLINE_THRESHOLD_SEC=180

# GPS ping cadence (seconds) sent to the mobile app. Lower moving interval =
# denser breadcrumbs and more accurate road tracing, at the cost of battery/data.
MOVING_INTERVAL_SEC=10
STATIONARY_INTERVAL_SEC=60

# ── Retention ────────────────────────────────────────────────────────────────
LOCATION_RETENTION_DAYS=90

# ── Worker cron schedules ────────────────────────────────────────────────────
CRON_STOP_DETECTION=*/1 * * * *
CRON_STALE_DETECTION=*/2 * * * *
CRON_DAILY_SUMMARY_CLOSE=5 0 * * *
CRON_RETENTION=30 1 * * *

# ── Seed (bootstrap admin created by `npm run seed`) ─────────────────────────
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@vmukti.com
SEED_ADMIN_PASSWORD=Admin@12345
# Set to true to RESET an existing admin's password to SEED_ADMIN_PASSWORD.
SEED_ADMIN_RESET=false
# Optional starting office location (you can change it later in the DB/dashboard).
SEED_OFFICE_NAME=Head Office
SEED_OFFICE_LAT=23.037760027900347
SEED_OFFICE_LNG=72.50345096369577

# ── Optional integrations ────────────────────────────────────────────────────
# Server-side reverse geocoding (Geocoding API). Leave blank to skip.
GOOGLE_MAPS_SERVER_KEY=AIzaSyD2CF3PlGBd0tQhusHwX3ngfPaad0pmJ_Q
# Path to a Firebase service-account JSON to enable FCM push. Leave blank to disable.
FCM_SERVICE_ACCOUNT_PATH=
